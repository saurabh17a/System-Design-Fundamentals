---
import type { DocEntry, Difficulty } from '../lib/docs';
import { breadcrumbs, docHref } from '../lib/docs';

interface Props {
	docs: DocEntry[];
}

const { docs } = Astro.props;

const RANK: Record<Difficulty, number> = { easy: 0, medium: 1, hard: 2 };
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
function diffOf(doc: DocEntry) {
	const sorted = [...doc.difficulty].sort((a, b) => RANK[a] - RANK[b]);
	if (!sorted.length) return null;
	return { label: sorted.map(cap).join(' → '), level: sorted[sorted.length - 1] };
}
function sectionTrail(doc: DocEntry) {
	const trail = breadcrumbs(doc); // [...sections, label]
	return trail.slice(0, -1).join(' / ');
}
---

<ul class="browse">
	{
		docs.map((doc) => {
			const d = diffOf(doc);
			return (
				<li class="doc-item" data-difficulty={doc.difficulty.join(' ') || undefined}>
					<a href={docHref(doc.id)}>
						<span class="trail">{sectionTrail(doc)}</span>
						<span class="label">{doc.label}</span>
						{d && (
							<span class={`badge ${d.level}`}>
								<span class="dot" />
								{d.label}
							</span>
						)}
					</a>
				</li>
			);
		})
	}
</ul>
<p class="browse-empty" id="browse-empty" hidden>No docs match the selected difficulty.</p>

<style>
	.browse {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 0.7rem;
	}
	a {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		height: 100%;
		padding: 1rem 1.1rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		background: var(--surface);
		text-decoration: none;
		transition:
			border-color 0.15s ease,
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}
	a:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow: var(--box-shadow);
	}
	.trail {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
	}
	.label {
		font-size: 1.05rem;
		font-weight: 700;
		color: rgb(var(--black));
		line-height: 1.25;
		flex: 1;
	}
	.badge {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.16rem 0.55rem;
		border-radius: 999px;
		font-size: 0.72rem;
		font-weight: 700;
		white-space: nowrap;
	}
	.badge .dot {
		width: 0.45rem;
		height: 0.45rem;
		border-radius: 50%;
		background: currentColor;
	}
	.badge.easy {
		background: rgba(22, 163, 74, 0.14);
		color: rgb(21, 128, 61);
	}
	.badge.medium {
		background: rgba(217, 119, 6, 0.15);
		color: rgb(180, 83, 9);
	}
	.badge.hard {
		background: rgba(220, 38, 38, 0.14);
		color: rgb(185, 28, 28);
	}
	.browse-empty {
		margin: 1.5rem 0 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
	html.dark .badge.easy {
		background: rgba(34, 197, 94, 0.16);
		color: rgb(134, 239, 172);
	}
	html.dark .badge.medium {
		background: rgba(245, 158, 11, 0.16);
		color: rgb(252, 211, 77);
	}
	html.dark .badge.hard {
		background: rgba(248, 113, 113, 0.16);
		color: rgb(252, 165, 165);
	}
</style>
