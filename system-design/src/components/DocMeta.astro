---
import type { Difficulty, Tag } from '../lib/docs';
import { companyHref, tagHref } from '../lib/docs';

interface Props {
	difficulty?: Difficulty[];
	tags?: Tag[];
	companies?: Tag[];
	type?: string;
}

const { difficulty = [], tags = [], companies = [], type } = Astro.props;

const RANK: Record<Difficulty, number> = { easy: 0, medium: 1, hard: 2 };
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const sortedDiff = [...difficulty].sort((a, b) => RANK[a] - RANK[b]);
const diffLabel = sortedDiff.map(cap).join(' → ');
const diffLevel = sortedDiff[sortedDiff.length - 1]; // hardest present drives the colour

const hasMeta = difficulty.length || tags.length || companies.length || type;
---

{
	hasMeta && (
		<div class="docmeta" data-pagefind-ignore>
			<div class="row primary">
				{diffLevel && (
					<span class={`badge diff ${diffLevel}`}>
						<span class="dot" />
						{diffLabel}
					</span>
				)}
				{type && <span class="badge type">{type}</span>}
				{tags.map((t) => (
					<a class="pill tag" href={tagHref(t.slug)}>
						<span class="hash">#</span>
						{t.label}
					</a>
				))}
			</div>
			{companies.length > 0 && (
				<div class="row companies">
					<span class="asked">Asked by</span>
					{companies.map((c) => (
						<a class="pill company" href={companyHref(c.slug)}>
							{c.label}
						</a>
					))}
				</div>
			)}
		</div>
	)
}

<style>
	.docmeta {
		margin: 0 0 2rem;
		padding: 0 0 1.4rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
	}
	.row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.45rem;
	}
	.companies {
		gap: 0.4rem;
	}
	.asked {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: rgb(var(--gray));
		margin-right: 0.15rem;
	}

	/* Difficulty badge — solid, colour-coded; the strongest visual anchor. */
	.badge {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.28rem 0.7rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 700;
		line-height: 1;
		white-space: nowrap;
	}
	.badge .dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: currentColor;
	}
	.diff.easy {
		background: rgba(22, 163, 74, 0.14);
		color: rgb(21, 128, 61);
	}
	.diff.medium {
		background: rgba(217, 119, 6, 0.15);
		color: rgb(180, 83, 9);
	}
	.diff.hard {
		background: rgba(220, 38, 38, 0.14);
		color: rgb(185, 28, 28);
	}
	.type {
		background: rgba(var(--gray-light), 0.6);
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-size: 0.72rem;
	}

	/* Topic pills — quiet, neutral, clickable. */
	.pill {
		display: inline-flex;
		align-items: center;
		gap: 0.1rem;
		padding: 0.26rem 0.6rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 600;
		text-decoration: none;
		border: 1px solid rgb(var(--gray-light));
		transition:
			border-color 0.14s ease,
			background 0.14s ease,
			color 0.14s ease;
	}
	.tag {
		color: rgb(var(--gray-dark));
		background: rgba(var(--gray-light), 0.45);
		border-color: transparent;
	}
	.tag .hash {
		color: rgb(var(--gray));
		font-weight: 700;
	}
	.tag:hover {
		color: var(--accent);
		background: rgba(var(--gray-light), 0.8);
	}

	/* Company chips — outlined, slightly stronger, clickable. */
	.company {
		color: rgb(var(--gray-dark));
		background: transparent;
		border-color: rgb(var(--gray-light));
	}
	.company:hover {
		border-color: var(--accent);
		color: var(--accent);
	}

	html.dark .diff.easy {
		background: rgba(34, 197, 94, 0.16);
		color: rgb(134, 239, 172);
	}
	html.dark .diff.medium {
		background: rgba(245, 158, 11, 0.16);
		color: rgb(252, 211, 77);
	}
	html.dark .diff.hard {
		background: rgba(248, 113, 113, 0.16);
		color: rgb(252, 165, 165);
	}
</style>
