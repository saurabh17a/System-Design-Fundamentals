---
import { GITHUB_URL, SITE_TITLE } from '../consts';
import { withBase } from '../lib/docs';
import Search from './Search.astro';

interface Props {
	hasSidebar?: boolean;
}

const { hasSidebar = false } = Astro.props;
const home = withBase('');
---

<header>
	<nav>
		{
			hasSidebar && (
				<button class="menu-toggle" aria-label="Toggle navigation" aria-expanded="false">
					<svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true">
						<path
							fill="currentColor"
							d="M1.5 3.5h13a.75.75 0 0 0 0-1.5h-13a.75.75 0 0 0 0 1.5Zm0 5h13a.75.75 0 0 0 0-1.5h-13a.75.75 0 0 0 0 1.5Zm0 5h13a.75.75 0 0 0 0-1.5h-13a.75.75 0 0 0 0 1.5Z"
						/>
					</svg>
				</button>
			)
		}
		<a class="brand" href={home}>
			<span class="brand-mark">SD</span>
			<span class="brand-text">{SITE_TITLE}</span>
		</a>
		<a class="navlink" href={withBase('tags')}>Topics</a>
		<a class="navlink" href={withBase('companies')}>Companies</a>
		<div class="spacer"></div>
		<Search />
		<button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle dark mode">
			<svg class="sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
				<path
					fill="currentColor"
					d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Zm0-5a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1Zm0 17a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1ZM4.2 4.2a1 1 0 0 1 1.4 0l.7.7A1 1 0 0 1 4.9 6.3l-.7-.7a1 1 0 0 1 0-1.4Zm13.4 13.4a1 1 0 0 1 1.4 0l.7.7a1 1 0 0 1-1.4 1.4l-.7-.7a1 1 0 0 1 0-1.4ZM2 12a1 1 0 0 1 1-1h1a1 1 0 1 1 0 2H3a1 1 0 0 1-1-1Zm17 0a1 1 0 0 1 1-1h1a1 1 0 1 1 0 2h-1a1 1 0 0 1-1-1ZM4.2 19.8a1 1 0 0 1 0-1.4l.7-.7a1 1 0 0 1 1.4 1.4l-.7.7a1 1 0 0 1-1.4 0ZM17.6 6.4a1 1 0 0 1 0-1.4l.7-.7a1 1 0 1 1 1.4 1.4l-.7.7a1 1 0 0 1-1.4 0Z"
				></path>
			</svg>
			<svg class="moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
				<path
					fill="currentColor"
					d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"
				></path>
			</svg>
		</button>
		<a class="gh" href={GITHUB_URL} target="_blank" rel="noopener" aria-label="View source on GitHub">
			<svg viewBox="0 0 16 16" width="24" height="24" aria-hidden="true"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		margin: 0;
		padding: 0 1.25em;
		background: color-mix(in srgb, var(--surface) 88%, transparent);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		height: 60px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
		color: rgb(var(--black));
		font-weight: 700;
		font-size: 1.05rem;
	}
	.brand-mark {
		display: grid;
		place-items: center;
		width: 30px;
		height: 30px;
		border-radius: 8px;
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		color: #fff;
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0.02em;
	}
	.navlink {
		font-size: 0.9rem;
		font-weight: 600;
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.navlink:hover {
		color: var(--accent);
	}
	.spacer {
		flex: 1;
	}
	.gh {
		display: flex;
		color: rgb(var(--gray-dark));
	}
	.gh:hover {
		color: var(--accent);
	}
	.menu-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		padding: 0.35rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		background: var(--surface);
		color: rgb(var(--gray-dark));
		cursor: pointer;
	}
	.icon-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		background: var(--surface);
		color: rgb(var(--gray-dark));
		cursor: pointer;
	}
	.icon-btn:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	/* Show moon in light mode (switch to dark), sun in dark mode. */
	.icon-btn .sun {
		display: none;
	}
	:global(html.dark) .icon-btn .sun {
		display: block;
	}
	:global(html.dark) .icon-btn .moon {
		display: none;
	}
	@media (max-width: 980px) {
		.menu-toggle {
			display: inline-flex;
		}
		.brand-text {
			display: none;
		}
		.navlink {
			display: none;
		}
		.spacer {
			flex: 0;
		}
	}
</style>

<script is:inline>
	(() => {
		const toggle = document.querySelector('.menu-toggle');
		if (toggle) {
			toggle.addEventListener('click', () => {
				const open = document.body.classList.toggle('nav-open');
				toggle.setAttribute('aria-expanded', String(open));
			});
		}

		const theme = document.getElementById('theme-toggle');
		if (theme) {
			theme.addEventListener('click', () => {
				const dark = document.documentElement.classList.toggle('dark');
				localStorage.setItem('theme', dark ? 'dark' : 'light');
			});
		}
	})();
</script>
