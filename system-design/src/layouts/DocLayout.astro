---
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Toc from '../components/Toc.astro';
import { withBase } from '../lib/docs';

interface Crumb {
	label: string;
	href?: string;
}

interface PagerLink {
	label: string;
	href: string;
}

interface Props {
	title: string;
	description: string;
	currentId: string;
	headings: MarkdownHeading[];
	crumbs: Crumb[];
	prev?: PagerLink | null;
	next?: PagerLink | null;
}

const { title, description, currentId, headings, crumbs, prev, next } = Astro.props;
const base = withBase('');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} · System Design`} description={description} />
	</head>
	<body>
		<Header />
		<div class="layout">
			<Sidebar currentId={currentId} />
			<main class="content">
				<nav class="breadcrumb" aria-label="Breadcrumb">
					<a href={base}>Home</a>
					{
						crumbs.map((c) => (
							<>
								<span class="sep">/</span>
								{c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
							</>
						))
					}
				</nav>
				<article class="prose" data-pagefind-body>
					<slot />
				</article>
				<nav class="pager" aria-label="Previous and next">
					{
						prev ? (
							<a class="prev" href={prev.href}>
								<span class="dir">← Previous</span>
								<span class="label">{prev.label}</span>
							</a>
						) : (
							<span />
						)
					}
					{
						next && (
							<a class="next" href={next.href}>
								<span class="dir">Next →</span>
								<span class="label">{next.label}</span>
							</a>
						)
					}
				</nav>
			</main>
			<Toc headings={headings} />
		</div>
		<Footer />
	</body>
</html>

<style>
	.layout {
		display: grid;
		grid-template-columns: 290px minmax(0, 1fr) 250px;
		max-width: 1440px;
		margin: 0 auto;
		gap: 0;
	}
	.content {
		min-width: 0;
		padding: 1.5rem clamp(1rem, 4vw, 3rem) 4rem;
	}
	.prose {
		max-width: 820px;
	}
	.breadcrumb {
		max-width: 820px;
		margin-bottom: 1.5rem;
		font-size: 0.85rem;
		color: rgb(var(--gray));
	}
	.breadcrumb a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.breadcrumb a:hover {
		color: var(--accent);
	}
	.breadcrumb .sep {
		margin: 0 0.4rem;
		opacity: 0.6;
	}

	.pager {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		max-width: 820px;
		margin-top: 3rem;
		padding-top: 1.5rem;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.pager a {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		max-width: 48%;
		padding: 0.75rem 1rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 10px;
		text-decoration: none;
		transition: border-color 0.15s ease;
	}
	.pager a:hover {
		border-color: var(--accent);
	}
	.pager .next {
		margin-left: auto;
		text-align: right;
	}
	.pager .dir {
		font-size: 0.75rem;
		color: rgb(var(--gray));
	}
	.pager .label {
		font-weight: 600;
		color: rgb(var(--black));
	}

	@media (max-width: 1200px) {
		.layout {
			grid-template-columns: 290px minmax(0, 1fr);
		}
	}
	@media (max-width: 980px) {
		.layout {
			display: block;
		}
	}
</style>
