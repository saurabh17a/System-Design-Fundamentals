---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { DEFAULT_SECTION_META, docHref, getNav, SECTION_META, withBase } from '../lib/docs';

const { groups, ordered } = await getNav();

const countOf = (key: string) => ordered.filter((d) => d.segments[0] === key).length;

const cards = groups.map((group) => {
	const count = ordered.filter((d) => d.segments[0] === group.key).length;
	const first = ordered.find((d) => d.segments[0] === group.key);
	const subAreas = group.groups.map((g) => g.label);
	return {
		key: group.key,
		label: group.label,
		count,
		href: first ? docHref(first.id) : '#',
		subAreas,
		...(SECTION_META[group.key] ?? DEFAULT_SECTION_META),
	};
});

// Every "start / browse" entry point lands on the methodology intro.
const startHref = docHref('methodology/01-what-is-system-design');

const stats = [
	{ n: countOf('hld'), label: 'System designs' },
	{ n: countOf('deepdives'), label: 'Deep dives' },
	{ n: countOf('lld'), label: 'LLD problems' },
	{ n: countOf('machinecoding'), label: 'Machine coding' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">{ordered.length} curated docs · Python &amp; Go</p>
				<h1>System Design,<br />from fundamentals to scale.</h1>
				<p class="lead">{SITE_DESCRIPTION}</p>
				<div class="cta">
					<a class="btn primary" href={startHref}>Start here — What is system design?</a>
					<a class="btn" href={withBase('tags')}>Browse by topic</a>
				</div>
				<ul class="stats">
					{
						stats.map((s) => (
							<li>
								<span class="num">{s.n}</span>
								<span class="lbl">{s.label}</span>
							</li>
						))
					}
				</ul>
			</section>

			<section class="section">
				<h2 class="section-title">Explore the tracks</h2>
				<div class="grid">
					{
						cards.map((card) => (
							<a class="card" href={card.href}>
								<div class="card-top">
									<span class="emoji">{card.emoji}</span>
									<span class="badge">{card.count}</span>
								</div>
								<h3>{card.label}</h3>
								<p>{card.blurb}</p>
								{card.subAreas.length > 0 && (
									<ul class="tags">
										{card.subAreas.slice(0, 6).map((s) => (
											<li>{s}</li>
										))}
										{card.subAreas.length > 6 && <li class="more">+{card.subAreas.length - 6}</li>}
									</ul>
								)}
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 1.25rem 4rem;
	}

	/* ---- Hero ---- */
	.hero {
		position: relative;
		padding: 5rem 0 3rem;
		text-align: center;
	}
	/* Soft radial glow behind the hero for depth. */
	.hero::before {
		content: '';
		position: absolute;
		inset: -20% -10% auto;
		height: 420px;
		background: radial-gradient(
			60% 60% at 50% 0%,
			color-mix(in srgb, var(--accent) 16%, transparent),
			transparent 70%
		);
		z-index: -1;
		pointer-events: none;
	}
	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.hero h1 {
		margin: 0 0 1rem;
		font-size: clamp(2.4rem, 6vw, 4rem);
		line-height: 1.05;
		background: linear-gradient(135deg, rgb(var(--black)), var(--accent));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}
	.lead {
		max-width: 640px;
		margin: 0 auto 2rem;
		font-size: 1.1rem;
		color: rgb(var(--gray-dark));
	}
	.cta {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	.btn {
		display: inline-block;
		padding: 0.7rem 1.4rem;
		border-radius: 10px;
		border: 1px solid rgb(var(--gray-light));
		font-weight: 600;
		text-decoration: none;
		color: rgb(var(--black));
		background: var(--surface);
		transition:
			border-color 0.15s ease,
			background 0.15s ease,
			transform 0.15s ease;
	}
	.btn:hover {
		border-color: var(--accent);
		transform: translateY(-1px);
	}
	.btn.primary {
		background: var(--accent);
		border-color: var(--accent);
		color: #fff;
	}
	.btn.primary:hover {
		background: var(--accent-dark);
	}

	/* ---- Stats strip ---- */
	.stats {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 2.5rem;
		list-style: none;
		margin: 3rem 0 0;
		padding: 1.5rem 0 0;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.stats li {
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.stats .num {
		font-size: 2rem;
		font-weight: 800;
		color: rgb(var(--black));
		line-height: 1;
	}
	.stats .lbl {
		margin-top: 0.35rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgb(var(--gray));
	}

	/* ---- Sections ---- */
	.section {
		margin-top: 3.5rem;
	}
	.section-title {
		margin: 0 0 1.25rem;
		font-size: 1.4rem;
	}

	/* ---- Track cards ---- */
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.25rem;
	}
	.card {
		display: block;
		padding: 1.5rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 16px;
		background: var(--surface);
		text-decoration: none;
		color: inherit;
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease,
			border-color 0.15s ease;
	}
	.card:hover {
		transform: translateY(-3px);
		box-shadow: var(--box-shadow);
		border-color: var(--accent);
	}
	.card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.75rem;
	}
	.emoji {
		font-size: 1.8rem;
	}
	.badge {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--accent);
		background: rgba(var(--gray-light), 0.7);
		padding: 0.15rem 0.6rem;
		border-radius: 999px;
	}
	.card h3 {
		margin: 0 0 0.4rem;
		font-size: 1.3rem;
	}
	.card p {
		margin: 0 0 1rem;
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
		line-height: 1.5;
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.tags li {
		font-size: 0.75rem;
		color: rgb(var(--gray-dark));
		background: rgba(var(--gray-light), 0.6);
		padding: 0.2rem 0.55rem;
		border-radius: 6px;
	}
	.tags .more {
		color: rgb(var(--gray));
	}
</style>
