---
import BaseHead from '../../components/BaseHead.astro';
import BrowseList from '../../components/BrowseList.astro';
import DifficultyFilter from '../../components/DifficultyFilter.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getTagIndex, withBase } from '../../lib/docs';

export async function getStaticPaths() {
	const tags = await getTagIndex();
	return tags.map((group) => ({ params: { tag: group.slug }, props: { group } }));
}

const { group } = Astro.props;
const title = `#${group.label}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} · System Design`} description={`Docs tagged ${group.label}.`} />
	</head>
	<body>
		<Header />
		<main class="browse-page">
			<a class="back" href={withBase('tags')}>← All topics</a>
			<header class="head">
				<h1><span class="hash">#</span>{group.label}</h1>
				<p>{group.docs.length} {group.docs.length === 1 ? 'doc' : 'docs'} on this topic</p>
			</header>
			<DifficultyFilter />
			<BrowseList docs={group.docs} />
		</main>
		<Footer />
	</body>
</html>

<style>
	.browse-page {
		max-width: 760px;
		margin: 0 auto;
		padding: 2.5rem clamp(1rem, 4vw, 2rem) 4rem;
	}
	.back {
		display: inline-block;
		margin-bottom: 1.5rem;
		font-size: 0.85rem;
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.back:hover {
		color: var(--accent);
	}
	.head {
		margin-bottom: 2rem;
	}
	.head h1 {
		margin: 0 0 0.3rem;
		font-size: 2.2rem;
	}
	.head .hash {
		color: rgb(var(--gray));
	}
	.head p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
</style>
