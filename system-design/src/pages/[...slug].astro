---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import DocLayout from '../layouts/DocLayout.astro';
import { breadcrumbs, docHref, getNav, prettifyDir } from '../lib/docs';

export async function getStaticPaths() {
	const entries = await getCollection('docs');
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

type Props = {
	entry: CollectionEntry<'docs'>;
};

const { entry } = Astro.props as Props;
const { Content, headings } = await render(entry);

const { ordered } = await getNav();
const doc = ordered.find((d) => d.id === entry.id)!;
const pos = ordered.indexOf(doc);
const prevDoc = pos > 0 ? ordered[pos - 1] : null;
const nextDoc = pos < ordered.length - 1 ? ordered[pos + 1] : null;

// The H1 is stripped from the rendered body (see strip-doc-meta plugin) and
// re-rendered as the page title by the layout — so read it from the raw source.
const rawH1 = entry.body?.match(/^#\s+(.+?)\s*$/m)?.[1];
const title = rawH1 ?? doc.label;

const crumbLabels = breadcrumbs(doc); // [...sections, pageLabel]
const crumbs = crumbLabels.slice(0, -1).map((label) => ({ label }));
---

<DocLayout
	title={title}
	description={doc.description}
	currentId={entry.id}
	headings={headings}
	crumbs={crumbs}
	prev={prevDoc ? { label: prevDoc.label, href: docHref(prevDoc.id) } : null}
	next={nextDoc ? { label: nextDoc.label, href: docHref(nextDoc.id) } : null}
	meta={{ difficulty: doc.difficulty, tags: doc.tags, companies: doc.companies, type: doc.type }}
>
	<Content />
</DocLayout>
